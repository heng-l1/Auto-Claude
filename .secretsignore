# .secretsignore - Patterns to exclude from secret scanning
# Each line is a regex pattern matched against file paths
# Lines starting with # are comments

# Test files - contain fake/mock tokens and credentials for testing
tests/test_auth\.py$
tests/test_client\.py$
tests/test_scan_secrets\.py$
tests/test_security_scanner\.py$
credential-utils\.test\.ts$
ProfileEditDialog\.test\.tsx$
ProfileList\.test\.tsx$

# Example files - educational code showing vulnerabilities
apps/backend/runners/github/validator_example\.py$

# Build scripts - contain public SHA256 checksums, not secrets
apps/frontend/scripts/download-python\.cjs$

# Token refresh - contains UUID patterns for OAuth client IDs, not secrets
apps/frontend/src/main/claude-profile/token-refresh\.ts$
